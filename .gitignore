# Squad: workstream advisory lock (local-only runtime file — never committed)
.squad/workstreams/active/*/.session-lock
# Squad: ignore transient state (inbox, sessions, scratch)
.squad/decisions/inbox/
.squad/sessions/
.squad/.scratch/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream
# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/.cache/
# Squad: per-request session state and SQLite database (operational, never committed)
.squad/session-state/
.squad/session-store.db
.squad/session-store.db-shm
.squad/session-store.db-wal
# Squad: scribe pre-check scratch file
.squad/scribe-prechecks.txt
# Node demo recording dependencies
node_modules/
